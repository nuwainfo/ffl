msgstr "架构：{system} {release} {machine} - {version} ({processor})"

#, python-brace-format
msgid "Support: {supportURL}"
msgstr "支援：{supportURL}"

msgid ""
"Recipient verification mode. 'pickup': 6-digit code required to download;"
" 'pubkey': RSA public-key challenge required; 'pubkey+pickup': both "
"required; 'email': one-time code sent to recipient's email"
msgstr ""
"收件人验证模式。'pickup'：下载需要 6 位数取件码；'pubkey'：需要 RSA "
"公钥验证；'pubkey+pickup'：两者皆需要；'email'：发送一次性验证码到收件人邮箱"

#, python-brace-format
msgid ""
"Custom {n}-digit pickup code (use with --recipient-auth pickup or "
"pubkey+pickup)"
msgstr "自定义 {n} 位数取件码（与 --recipient-auth pickup 或 pubkey+pickup 搭配使用）"

#, python-brace-format
msgid ""
"Path to recipient RSA public key file ({ext}), or a comma-separated list "
"of paths (implies --recipient-auth pubkey; with --pickup-code, implies "
"pubkey+pickup)"
msgstr ""

msgid ""
"Recipient email address, or a comma-separated list of email addresses, "
"for OTP verification (implies --recipient-auth email)"
msgstr ""

msgid ""
"Base URL for OTP email API (e.g. https://myserver.com/api). Required for "
"--recipient-auth email"
msgstr ""
"OTP 邮箱 API 的基础 URL（例如 https://myserver.com/api）。使用 --recipient-auth email"
" 时必填"

msgid "Choose a file or folder you want to share (use '-' for stdin)"
msgstr "选择要分享的文件或文件夹（使用 '-' 表示标准输入）"

msgid ""
"Specify custom download filename (default: original filename for files, "
"folder.zip for folders, stdin-YYYYMMDD-HHMMSS.bin for stdin)"
msgstr "指定自定义下载文件名（默认：文件使用原始文件名，文件夹使用 folder.zip，标准输入使用 stdin-YYYYMMDD-HHMMSS.bin）"

msgid "Output link and settings to a JSON file"
msgstr "将连结和设定输出到 JSON 档案"

#, python-brace-format
msgid ""
"Upload file to FastFileLink server to share it (Share duration after "
"upload). Default: {default}"
msgstr "上传档案到 快档连结 云端以分享（上传后的分享期限）。预设：{default}"

msgid ""
"Resume a previously interrupted upload (requires previous upload session "
"to exist)"
msgstr "继续先前中断的上传（需要先前的上传工作阶段存在）"

msgid "Pause upload at specified percentage (1-99, requires --upload)"
msgstr "在指定百分比时暂停上传（1-99，需要 --upload）"

msgid ""
"Maximum number of downloads before the server automatically shuts down "
"(P2P mode only). 0 means unlimited."
msgstr "伺服器自动关闭前的最大下载次数（仅限 P2P 模式）。0 表示无限制。"

msgid ""
"Timeout in seconds before the server automatically shuts down (P2P mode "
"only). 0 means no timeout."
msgstr "伺服器自动关闭前的逾时秒数（仅限 P2P 模式）。0 表示无逾时。"

msgid ""
"Port number for local server (1024-65535, default: auto-detect available "
"port)"
msgstr "本地伺服器的连接埠号码（1024-65535，预设：自动侦测可用连接埠）"

#, python-brace-format
msgid "Username for HTTP Basic Authentication (default: '{default}')"
msgstr "HTTP 基本验证的使用者名称（预设：'{default}'）"

msgid "Password for HTTP Basic Authentication (enables auth protection)"
msgstr "HTTP 基本验证的密码（启用验证保护）"

msgid ""
"Force relayed P2P mode, disable direct WebRTC connections (can be "
"overridden by ?webrtc=on URL parameter)"
msgstr "强制中继 P2P 模式，停用直接 WebRTC 连线（可由 ?webrtc=on URL 参数覆写）"

msgid "Enable end-to-end encryption for file sharing (both HTTP and WebRTC)"
msgstr "启用档案分享的端对端加密（HTTP 和 WebRTC）"

msgid "Open invite page in browser with the sharing link"
msgstr "在浏览器中开启包含分享连结的邀请页面"

msgid "Display QR code in terminal (default) or save to FILE (e.g., qr.png)"
msgstr "在终端中显示二维码（默认）或保存到文件（例如 qr.png）"

msgid ""
"Start VFS server and provide vfs:// URI instead of HTTPS link (P2P mode "
"only, works with --port)"
msgstr "启动 VFS 伺服器并提供 vfs:// URI 而不是 HTTPS 连结（仅限 P2P 模式，与 --port 一起使用）"

#, python-brace-format
msgid "Invalid log level '{logLevel}'. Valid levels are: {validLevels}"
msgstr "无效的记录层级 '{logLevel}'。有效层级为：{validLevels}"

msgid "Show version information and enabled addons"
msgstr "显示版本资讯和已启用的附加元件"

msgid "Run in CLI mode without GUI (optional)"
msgstr "以 CLI 模式执行而不使用 GUI（选用）"

msgid ""
"Set logging level (DEBUG, INFO, WARNING, ERROR) or path to logging config"
" JSON file (default: WARNING)"
msgstr "设定记录层级（DEBUG、INFO、WARNING、ERROR）或记录设定 JSON 档案的路径（预设：WARNING）"

msgid ""
"Proxy server for all outbound connections. Formats: [user:pass@]host:port"
" (defaults to SOCKS5), socks5[h]://[user:pass@]host:port, "
"http[s]://[user:pass@]host:port. SOCKS5 proxies work for both tunnel and "
"HTTP requests. HTTP proxies only work for HTTP requests (not tunnel)"
msgstr ""
"所有出站连线的代理伺服器。格式：[user:pass@]host:port（预设为 "
"SOCKS5）、socks5[h]://[user:pass@]host:port、http[s]://[user:pass@]host:port。SOCKS5"
" 代理适用于通道和 HTTP 请求。HTTP 代理仅适用于 HTTP 请求（不适用于通道）"

msgid ""
"Webhook URL for forwarding events to parent process or external service. "
"Format: http://[user:pass@]host:port/path (e.g., "
"http://app:token@127.0.0.1:12345/events). Auth credentials are optional "
"but recommended."
msgstr ""
"用于将事件转发到父进程或外部服务的 Webhook "
"URL。格式：http://[user:pass@]host:port/path（例如：http://app:token@127.0.0.1:12345/events）。认证凭据是可选的，但建议使用。"

msgid "FastFileLink makes file sharing fast, simple, and secure."
msgstr "快档连结 让档案分享快速、简单且安全。"

msgid "Available commands"
msgstr "可用命令"

msgid "Share a file (default command)"
msgstr "分享档案（预设命令）"

msgid "Download a file from FastFileLink URL"
msgstr "从 快档连结 URL 下载档案"

msgid "FastFileLink URL to download from"
msgstr "要下载的 快档连结 URL"

msgid "Output file path (default: use filename from server)"
msgstr "输出档案路径（预设：使用来自伺服器的档案名称）"

msgid ""
"Resume incomplete download (like curl -C), otherwise overwrite existing "
"file"
msgstr "继续未完成的下载（类似 curl -C），否则覆写现有档案"

msgid "Password for HTTP Basic Authentication"
msgstr "HTTP 基本验证的密码"

msgid "Recipient verification mode when downloading a protected file"
msgstr "下载受保护文件时的收件人验证模式"

msgid ""
"Pickup code to present when downloading (use with --recipient-auth pickup"
