msgstr "错误：--recipient-auth email 需要 OTP API 服务器"

msgid "Use --recipient-otp-api-base to specify one"
msgstr "使用 --recipient-otp-api-base 指定一个"

#, python-brace-format
msgid "Error: --recipient-public-key is required with --recipient-auth {mode}"
msgstr "错误：使用 --recipient-auth {mode} 时必须提供 --recipient-public-key"

#, python-brace-format
msgid "Use --recipient-public-key {name}{ext}"
msgstr "使用方式：--recipient-public-key {name}{ext}"

