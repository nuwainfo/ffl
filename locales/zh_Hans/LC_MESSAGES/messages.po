msgstr "无法写入 JSON 档案：{error}"

msgid "You can stop the upload at any time and resume it later.\n"
msgstr "您可以随时停止上传并稍后继续。\n"

#, python-brace-format
msgid ""
"Upload paused at {percentage:.1f}% ({completedChunks}/{totalChunks} "
"chunks completed)"
msgstr "上传已暂停于 {percentage:.1f}%（已完成 {completedChunks}/{totalChunks} 个区块）"

msgid "Use --resume to continue upload"
msgstr "使用 --resume 继续上传"

msgid ""
"Resume is only available for direct upload mode (without external "
"tunnels).\n"
"Please restart the upload without --resume to upload the file normally."
msgstr ""
"继续上传仅适用于直接上传模式（不使用外部通道）。\n"
"请在不使用 --resume 的情况下重新启动上传以正常上传档案。"

msgid ""
"Pause functionality is only available for direct upload mode (without "
"external tunnels).\n"
"Please restart the upload without --pause to upload the file normally."
msgstr ""
"暂停功能仅适用于直接上传模式（不使用外部通道）。\n"
"请在不使用 --pause 的情况下重新启动上传以正常上传档案。"

msgid ""
"End-to-end encryption is only available for direct upload mode (without "
"external tunnels).\n"
"Please restart the upload without --e2ee to upload the file normally."
msgstr ""
"端对端加密仅适用于直接上传模式（不使用外部通道）。\n"
"请在不使用 --e2ee 的情况下重新启动上传以正常上传档案。"

#, python-brace-format
msgid ""
"Cannot resume: {parameter} mismatch.\n"
"Original upload used \"{originalValue}\" but \"{requestedValue}\" was "
"requested.\n"
"Please use the same parameters as the original upload."
msgstr ""
"无法继续：{parameter} 不匹配。\n"
"原始上传使用 \"{originalValue}\"，但要求使用 \"{requestedValue}\"。\n"
"请使用与原始上传相同的参数。"

msgid "Unknown error"
msgstr "未知错误"

msgid ""
"Your user points are not enough. Please top up on our website "
"(https://fastfilelink.com/)."
msgstr "您的使用者点数不足。请在我们的网站上储值 (https://fastfilelink.com/)。"

msgid "Upload not allowed."
msgstr "不允许上传。"

msgid "Retrying...\n"
msgstr "正在重试...\n"

