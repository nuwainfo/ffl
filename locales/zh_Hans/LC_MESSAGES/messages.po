msgstr "通道伺服器暂时无法使用。请参阅 https://github.com/nuwainfo/ffl#3--using-tunnels 以了解替代通道。"

msgid "Failed to connect server"
msgstr "无法连线到云端"

msgid "Server return error"
msgstr "伺服器回传错误"

#, python-brace-format
msgid "Loading .env file from: {envFilePath}"
msgstr "正在从以下位置载入 .env 档案：{envFilePath}"

