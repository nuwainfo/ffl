msgstr "要升级的目标二进位档路径（用于开发模式），或版本（例如：v3.7.5）"

msgid "Target version when binary path is specified (default: latest)"
msgstr "指定二进位档路径时的目标版本（预设：最新）"

msgid "Generate an RSA-2048 keypair for --recipient-auth pubkey"
msgstr "为 --recipient-auth pubkey 生成 RSA-2048 密钥对"

#, python-brace-format
msgid ""
"Base name for keypair files (default: recipient → recipient{pub} + "
