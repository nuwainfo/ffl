msgstr "📁 以 ZIP 格式分享资料夹 - 请在传输过程中保持资料夹内容不变\n"

msgid "🔐 End-to-end encryption enabled\n"
msgstr "🔐 已启用端对端加密\n"

msgid "🧅 Tor Privacy Mode Active"
msgstr "🧅 Tor 隐私模式已启用"

