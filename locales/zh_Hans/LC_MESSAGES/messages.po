msgstr "错误：VFS 模式需要文件或文件夹路径"

msgid "VFS server started successfully!\n"
msgstr "VFS 伺服器已成功启动！\n"

#, python-brace-format
msgid "Please share the URI below to access the {type} remotely:\n"
msgstr "请分享以下 URI 以远程访问{type}：\n"

