msgstr "取件码：{code}\n"

msgid "Opening invite page in browser..."
msgstr "正在浏览器中开启邀请页面..."

#, python-brace-format
msgid "QR code saved to: {filePath}"
msgstr "二维码已保存到：{filePath}"

msgid ""
"\n"
"QR Code:\n"
msgstr ""
"\n"
"二维码：\n"

