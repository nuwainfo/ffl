#, python-brace-format
msgid "Authentication enabled - Username: {authUser}\n"
msgstr "已啟用身份驗證 - 使用者名稱：{authUser}\n"

#, python-brace-format
msgid "Pickup code: {code}\n"
msgstr "取件碼：{code}\n"

msgid "Opening invite page in browser..."
msgstr "正在瀏覽器中開啟邀請頁面..."

#, python-brace-format
msgid "QR code saved to: {filePath}"
msgstr "QR code 已儲存到：{filePath}"

msgid ""
"\n"
"QR Code:\n"
msgstr ""
"\n"
"QR Code：\n"

#, python-brace-format
msgid "Error generating QR code: {error}"
msgstr "產生 QR code 時出錯：{error}"

#, python-brace-format
msgid "Sharing information saved to {jsonFile}"
msgstr "分享資訊已儲存至 {jsonFile}"

#, python-brace-format
msgid "Failed to write JSON file: {error}"
msgstr "無法寫入 JSON 檔案：{error}"

msgid "You can stop the upload at any time and resume it later.\n"
msgstr "您可以隨時停止上傳並稍後繼續。\n"

#, python-brace-format
msgid ""
"Upload paused at {percentage:.1f}% ({completedChunks}/{totalChunks} "
"chunks completed)"
msgstr "上傳已暫停於 {percentage:.1f}%（已完成 {completedChunks}/{totalChunks} 個區塊）"

msgid "Use --resume to continue upload"
msgstr "使用 --resume 繼續上傳"

msgid ""
"Resume is only available for direct upload mode (without external "
"tunnels).\n"
"Please restart the upload without --resume to upload the file normally."
msgstr ""
"繼續上傳僅適用於直接上傳模式（不使用外部通道）。\n"
"請在不使用 --resume 的情況下重新啟動上傳以正常上傳檔案。"

msgid ""
"Pause functionality is only available for direct upload mode (without "
"external tunnels).\n"
"Please restart the upload without --pause to upload the file normally."
msgstr ""
"暫停功能僅適用於直接上傳模式（不使用外部通道）。\n"
"請在不使用 --pause 的情況下重新啟動上傳以正常上傳檔案。"

msgid ""
"End-to-end encryption is only available for direct upload mode (without "
"external tunnels).\n"
"Please restart the upload without --e2ee to upload the file normally."
msgstr ""
"端對端加密僅適用於直接上傳模式（不使用外部通道）。\n"
"請在不使用 --e2ee 的情況下重新啟動上傳以正常上傳檔案。"

#, python-brace-format
msgid ""
"Cannot resume: {parameter} mismatch.\n"
"Original upload used \"{originalValue}\" but \"{requestedValue}\" was "
"requested.\n"
"Please use the same parameters as the original upload."
msgstr ""
"無法繼續：{parameter} 不匹配。\n"
"原始上傳使用 \"{originalValue}\"，但要求使用 \"{requestedValue}\"。\n"
"請使用與原始上傳相同的參數。"

msgid "Unknown error"
msgstr "未知錯誤"

msgid ""
"Your user points are not enough. Please top up on our website "
"(https://fastfilelink.com/)."
msgstr "您的使用者點數不足。請在我們的網站上儲值 (https://fastfilelink.com/)。"

msgid "Upload not allowed."
msgstr "不允許上傳。"

msgid "Retrying...\n"
msgstr "正在重試...\n"

msgid "Error: VFS mode requires a file or folder path"
msgstr "錯誤：VFS 模式需要檔案或資料夾路徑"

msgid "VFS server started successfully!\n"
msgstr "VFS 伺服器已成功啟動！\n"

#, python-brace-format
msgid "Please share the URI below to access the {type} remotely:\n"
msgstr "請分享以下 URI 以遠端存取{type}：\n"

msgid ""
"VFS server is running on loopback (127.0.0.1) - only accessible from this"
" machine."
msgstr "VFS 伺服器正在環回位址（127.0.0.1）上執行 - 僅可從本機存取。"

msgid "Please keep the application running for remote access."
msgstr "請保持應用程式執行以進行遠端存取。"

msgid "Press Ctrl+C to stop the server.\n"
msgstr "按 Ctrl+C 停止伺服器。\n"

msgid ""
"\n"
"Shutting down VFS server..."
msgstr ""
"\n"
"正在關閉 VFS 伺服器..."

msgid "VFS server stopped."
msgstr "VFS 伺服器已停止。"

#, python-brace-format
msgid "{file} does not exist!"
msgstr "{file} 不存在！"

msgid "Error: Upload functionality requires Upload addon (addons/Upload.py)"
msgstr "錯誤：上傳功能需要 Upload 附加元件 (addons/Upload.py)"

msgid "User email address has been lost"
msgstr "使用者電子郵件地址已遺失"

msgid ""
"If a firewall notification appears, please allow the application to "
"connect.\n"
msgstr "如果出現防火牆通知，請允許應用程式連線。\n"

msgid ""
"📁 Sharing folder as ZIP - please keep folder contents unchanged during "
"transfer\n"
msgstr "📁 以 ZIP 格式分享資料夾 - 請在傳輸過程中保持資料夾內容不變\n"

msgid "🔐 End-to-end encryption enabled\n"
msgstr "🔐 已啟用端對端加密\n"

msgid "🧅 Tor Privacy Mode Active"
msgstr "🧅 Tor 隱私模式已啟用"

msgid "Unable to create tunnel by your tunnel configuration."
msgstr "無法使用您的通道配置建立通道。"

#, python-brace-format
msgid "Using tunnel: {tunnelType}"
msgstr "使用通道：{tunnelType}"

#, python-brace-format
msgid "Establishing tunnel connection via proxy {proxyInfo}...\n"
msgstr "正在透過代理 {proxyInfo} 建立通道連線...\n"

msgid "Establishing tunnel connection...\n"
msgstr "正在建立通道連線...\n"

#, python-brace-format
msgid "Upload failed: {error}"
msgstr "上傳失敗：{error}"

msgid ""
"Please share the link below with the person you'd like to share the file "
"with."
msgstr "請將以下連結分享給您想要分享檔案的人。"

msgid ""
"Please keep the application running so the recipient can download the "
"file."
msgstr "請保持應用程式運作，以便接收者可以下載檔案。"

msgid "Press Ctrl+C to terminate the program when done.\n"
msgstr "完成後請按 Ctrl+C 終止程式。\n"

msgid ""
"\n"
"Exiting on user request (Ctrl+C)..."
msgstr ""
"\n"
"應使用者要求退出 (Ctrl+C)..."

msgid "Unable to get uploaded link"
msgstr "無法取得上傳連結"

#, python-brace-format
msgid "Downloaded: {outputPath}"
msgstr "已下載：{outputPath}"

#, python-brace-format
msgid ""
"{serverMsg}\n"
"\n"
"The shared folder contents changed during the transfer.\n"
"Please contact the person who shared the file and ask them to share it "
"again."
msgstr ""
"{serverMsg}\n"
"\n"
"共享資料夾的內容在傳輸過程中發生變更。\n"
"請聯絡分享檔案的人並要求他們重新分享。"

#, python-brace-format
msgid "Download failed: {error}"
msgstr "下載失敗：{error}"

msgid "GUI support not available. Install required dependencies or use CLI mode."
msgstr "GUI 支援不可用。請安裝所需的相依套件或使用 CLI 模式。"

msgid "Error: App has not been registered"
msgstr "錯誤：應用程式尚未註冊"

msgid "App has not been registered"
msgstr "應用程式尚未註冊"

msgid ""
"Tunnel server temporarily unavailable. See "
"https://github.com/nuwainfo/ffl#3--using-tunnels for alternative tunnels."
msgstr "通道伺服器暫時無法使用。請參閱 https://github.com/nuwainfo/ffl#3--using-tunnels 以了解替代通道。"

msgid "Failed to connect server"
msgstr "無法連線到雲端"

msgid "Server return error"
msgstr "伺服器回傳錯誤"

#, python-brace-format
msgid "Loading .env file from: {envFilePath}"
msgstr "正在從以下位置載入 .env 檔案：{envFilePath}"

#, python-brace-format
msgid "Warning: .env line {lineNum}: Invalid format (missing =): {line}"
msgstr "警告：.env 第 {lineNum} 行：格式無效（缺少 =）：{line}"

#, python-brace-format
msgid "Warning: .env line {lineNum}: Empty key"
msgstr "警告：.env 第 {lineNum} 行：空的鍵"

#, python-brace-format
msgid "Loaded {loadedCount} environment variables from .env"
msgstr "已從 .env 載入 {loadedCount} 個環境變數"

#, python-brace-format
msgid "Error: Unexpected error loading .env file: {error}"
msgstr "錯誤：載入 .env 檔案時發生意外錯誤：{error}"

