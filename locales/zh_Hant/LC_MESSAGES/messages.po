msgstr "無法從 {logLevel} 載入日誌配置：{error}"

msgid "Falling back to default logging level configuration"
msgstr "退回到預設日誌層級配置"

#, python-brace-format
msgid "FastFileLink v{version}"
msgstr "快檔連結 v{version}"

msgid "🔄 Update available!"
msgstr "🔄 有可用更新！"

#, python-brace-format
msgid "   Your version: {version}"
msgstr "   您的版本：{version}"

#, python-brace-format
msgid "   Latest version: {serverVersion}"
msgstr "   最新版本：{serverVersion}"

msgid "   Consider updating for the latest features and improvements."
msgstr "   請考慮更新以獲得最新功能和改進。"

msgid "⚠️ VERSION INCOMPATIBLE!"
msgstr "⚠️ 版本不相容！"

#, python-brace-format
msgid "   Server Minimum required: {minimumVersion}"
msgstr "   伺服器最低要求版本：{minimumVersion}"

msgid "   Please update to continue using the service."
msgstr "   請更新以繼續使用服務。"

msgid "Enabled addons:"
msgstr "已啟用的附加元件："

msgid "[OK] Loaded"
msgstr "[正常] 已載入"

msgid "[FAIL] Failed to load"
msgstr "[失敗] 載入失敗"

msgid "[UNKNOWN] Not loaded"
msgstr "[未知] 未載入"

msgid "No addons available"
msgstr "沒有可用的附加元件"

#, python-brace-format
msgid "Architecture: {system} {release} {machine} - {version} ({processor})"
msgstr "架構：{system} {release} {machine} - {version} ({processor})"

#, python-brace-format
msgid "Support: {supportURL}"
msgstr "支援：{supportURL}"

msgid ""
"Recipient verification mode. 'pickup': 6-digit code required to download;"
" 'pubkey': RSA public-key challenge required; 'pubkey+pickup': both "
"required; 'email': one-time code sent to recipient's email"
msgstr ""
"收件人驗證模式。'pickup'：下載需要 6 位數取件碼；'pubkey'：需要 RSA "
"公鑰驗證；'pubkey+pickup'：兩者皆需要；'email'：傳送一次性驗證碼到收件人信箱"

#, python-brace-format
msgid ""
"Custom {n}-digit pickup code (use with --recipient-auth pickup or "
"pubkey+pickup)"
msgstr "自訂 {n} 位數取件碼（與 --recipient-auth pickup 或 pubkey+pickup 搭配使用）"

#, python-brace-format
msgid ""
"Path to recipient RSA public key file ({ext}), or a comma-separated list "
"of paths (implies --recipient-auth pubkey; with --pickup-code, implies "
"pubkey+pickup)"
msgstr ""

msgid ""
"Recipient email address, or a comma-separated list of email addresses, "
"for OTP verification (implies --recipient-auth email)"
msgstr ""

msgid ""
"Base URL for OTP email API (e.g. https://myserver.com/api). Required for "
"--recipient-auth email"
msgstr ""
"OTP 信箱 API 的基礎 URL（例如 https://myserver.com/api）。使用 --recipient-auth email"
" 時必填"

msgid "Choose a file or folder you want to share (use '-' for stdin)"
msgstr "選擇要分享的檔案或資料夾（使用 '-' 表示標準輸入）"

msgid ""
"Specify custom download filename (default: original filename for files, "
"folder.zip for folders, stdin-YYYYMMDD-HHMMSS.bin for stdin)"
msgstr ""
"指定自訂下載檔案名稱（預設：檔案使用原始檔案名稱，資料夾使用 folder.zip，標準輸入使用 stdin-YYYYMMDD-"
"HHMMSS.bin）"

msgid "Output link and settings to a JSON file"
msgstr "將連結和設定輸出到 JSON 檔案"

#, python-brace-format
msgid ""
"Upload file to FastFileLink server to share it (Share duration after "
"upload). Default: {default}"
msgstr "上傳檔案到 快檔連結 雲端以分享（上傳後的分享期限）。預設：{default}"

msgid ""
"Resume a previously interrupted upload (requires previous upload session "
"to exist)"
msgstr "繼續先前中斷的上傳（需要先前的上傳工作階段存在）"

msgid "Pause upload at specified percentage (1-99, requires --upload)"
msgstr "在指定百分比時暫停上傳（1-99，需要 --upload）"

msgid ""
"Maximum number of downloads before the server automatically shuts down "
"(P2P mode only). 0 means unlimited."
msgstr "雲端自動關閉前的最大下載次數（僅限 P2P 模式）。0 表示無限制。"

msgid ""
"Timeout in seconds before the server automatically shuts down (P2P mode "
"only). 0 means no timeout."
msgstr "雲端自動關閉前的逾時秒數（僅限 P2P 模式）。0 表示無逾時。"

msgid ""
"Port number for local server (1024-65535, default: auto-detect available "
"port)"
msgstr "本地伺服器的連接埠號碼（1024-65535，預設：自動偵測可用連接埠）"

#, python-brace-format
msgid "Username for HTTP Basic Authentication (default: '{default}')"
msgstr "HTTP 基本驗證的使用者名稱（預設：'{default}'）"

msgid "Password for HTTP Basic Authentication (enables auth protection)"
msgstr "HTTP 基本驗證的密碼（啟用驗證保護）"

msgid ""
"Force relayed P2P mode, disable direct WebRTC connections (can be "
"overridden by ?webrtc=on URL parameter)"
msgstr "強制中繼 P2P 模式，停用直接 WebRTC 連線（可由 ?webrtc=on URL 參數覆寫）"

msgid "Enable end-to-end encryption for file sharing (both HTTP and WebRTC)"
msgstr "啟用檔案分享的端對端加密（HTTP 和 WebRTC）"

msgid "Open invite page in browser with the sharing link"
msgstr "在瀏覽器中開啟包含分享連結的邀請頁面"

msgid "Display QR code in terminal (default) or save to FILE (e.g., qr.png)"
msgstr "在終端機中顯示 QR code（預設）或儲存到檔案（例如 qr.png）"

msgid ""
"Start VFS server and provide vfs:// URI instead of HTTPS link (P2P mode "
"only, works with --port)"
msgstr "啟動 VFS 伺服器並提供 vfs:// URI 而不是 HTTPS 連結（僅限 P2P 模式，與 --port 一起使用）"

#, python-brace-format
msgid "Invalid log level '{logLevel}'. Valid levels are: {validLevels}"
msgstr "無效的記錄層級 '{logLevel}'。有效層級為：{validLevels}"

msgid "Show version information and enabled addons"
msgstr "顯示版本資訊和已啟用的附加元件"

msgid "Run in CLI mode without GUI (optional)"
msgstr "以 CLI 模式執行而不使用 GUI（選用）"

msgid ""
"Set logging level (DEBUG, INFO, WARNING, ERROR) or path to logging config"
" JSON file (default: WARNING)"
msgstr "設定記錄層級（DEBUG、INFO、WARNING、ERROR）或記錄設定 JSON 檔案的路徑（預設：WARNING）"

msgid ""
"Proxy server for all outbound connections. Formats: [user:pass@]host:port"
" (defaults to SOCKS5), socks5[h]://[user:pass@]host:port, "
"http[s]://[user:pass@]host:port. SOCKS5 proxies work for both tunnel and "
"HTTP requests. HTTP proxies only work for HTTP requests (not tunnel)"
msgstr ""
"所有出站連線的代理伺服器。格式：[user:pass@]host:port（預設為 "
"SOCKS5）、socks5[h]://[user:pass@]host:port、http[s]://[user:pass@]host:port。SOCKS5"
" 代理適用於通道和 HTTP 請求。HTTP 代理僅適用於 HTTP 請求（不適用於通道）"

msgid ""
"Webhook URL for forwarding events to parent process or external service. "
"Format: http://[user:pass@]host:port/path (e.g., "
"http://app:token@127.0.0.1:12345/events). Auth credentials are optional "
"but recommended."
msgstr ""
"用於將事件轉發到父程序或外部服務的 Webhook "
"URL。格式：http://[user:pass@]host:port/path（例如：http://app:token@127.0.0.1:12345/events）。認證憑據是可選的，但建議使用。"

msgid "FastFileLink makes file sharing fast, simple, and secure."
msgstr "快檔連結 讓檔案分享快速、簡單且安全。"

msgid "Available commands"
msgstr "可用命令"

msgid "Share a file (default command)"
msgstr "分享檔案（預設命令）"

msgid "Download a file from FastFileLink URL"
msgstr "從 快檔連結 URL 下載檔案"

msgid "FastFileLink URL to download from"
msgstr "要下載的 快檔連結 URL"

msgid "Output file path (default: use filename from server)"
msgstr "輸出檔案路徑（預設：使用來自伺服器的檔案名稱）"

msgid ""
"Resume incomplete download (like curl -C), otherwise overwrite existing "
"file"
msgstr "繼續未完成的下載（類似 curl -C），否則覆寫現有檔案"

msgid "Password for HTTP Basic Authentication"
msgstr "HTTP 基本驗證的密碼"

msgid "Recipient verification mode when downloading a protected file"
msgstr "下載受保護檔案時的收件人驗證模式"

msgid ""
"Pickup code to present when downloading (use with --recipient-auth pickup"
" or pubkey+pickup)"
msgstr "下載時提供的取件碼（與 --recipient-auth pickup 或 pubkey+pickup 搭配使用）"

#, python-brace-format
msgid "Path to recipient's RSA private key file ({ext}) for pubkey auth"
msgstr "用於公鑰驗證的收件人 RSA 私鑰檔案路徑（{ext}）"

msgid "Upgrade to latest version or specified version"
msgstr "升級到最新版本或指定版本"

msgid ""
"Target binary path to upgrade (for development mode), or version (e.g., "
"v3.7.5)"
msgstr "要升級的目標二進位檔路徑（用於開發模式），或版本（例如：v3.7.5）"

msgid "Target version when binary path is specified (default: latest)"
msgstr "指定二進位檔路徑時的目標版本（預設：最新）"

msgid "Generate an RSA-2048 keypair for --recipient-auth pubkey"
msgstr "為 --recipient-auth pubkey 產生 RSA-2048 金鑰對"

#, python-brace-format
msgid ""
"Base name for keypair files (default: recipient → recipient{pub} + "
"recipient{priv})"
msgstr "金鑰對檔案的基礎名稱（預設：recipient → recipient{pub} + recipient{priv}）"

msgid ""
"Share the generated private key immediately after generation (private key"
" can only be downloaded once, then auto-deleted; recommended: add "
"--recipient-auth pickup or --recipient-auth pubkey)"
msgstr ""
"產生後立即分享私鑰（私鑰只能下載一次，之後自動刪除；建議加上 --recipient-auth pickup 或 --recipient-auth"
" pubkey）"

msgid "Output link and settings to a JSON file (use with --share)"
msgstr "將連結和設定輸出到 JSON 檔案（與 --share 搭配使用）"

#, python-brace-format
msgid "Error: Invalid proxy format: {proxy}"
msgstr "錯誤：無效的代理格式：{proxy}"

msgid "Generated RSA-2048 keypair:"
msgstr "已產生 RSA-2048 金鑰對："

#, python-brace-format
msgid "  Private key : {path}"
msgstr "  私鑰：{path}"

#, python-brace-format
msgid "  Public key  : {path}  ← share with sender"
msgstr "  公鑰：{path}  ← 分享給寄件人"

msgid "Share the public key file with the sender who will use:"
msgstr "將公鑰檔案分享給寄件人，對方將使用："

#, python-brace-format
msgid "  ffl share file.bin --recipient-auth pubkey --recipient-public-key {pub}"
msgstr "  ffl share file.bin --recipient-auth pubkey --recipient-public-key {pub}"

#, python-brace-format
msgid "Private key deleted: {path}"
msgstr "私鑰已刪除：{path}"

msgid "Sharing private key (download once, then auto-deleted)."
msgstr "正在分享私鑰（只能下載一次，之後自動刪除）。"

msgid ""
"Tip: use --recipient-auth pickup or --recipient-auth pubkey to restrict "
"who can download.\n"
msgstr "提示：使用 --recipient-auth pickup 或 --recipient-auth pubkey 限制誰可以下載。\n"

msgid "Error: --upload option requires Upload addon (addons/Upload.py)"
msgstr "錯誤：--upload 選項需要 Upload 附加元件（addons/Upload.py）"

msgid ""
"Please install the Upload addon (use Standard/Plus version) or use P2P "
"mode without --upload"
msgstr "請安裝 Upload 附加元件（使用 Standard/Plus 版本）或使用不帶 --upload 的 P2P 模式"

msgid "Error: --pause requires --upload"
msgstr "錯誤：--pause 需要 --upload"

msgid "Use: --upload <duration> --pause <percentage>"
msgstr "使用方式：--upload <持續時間> --pause <百分比>"

msgid "Error: --pause percentage must be between 1 and 99"
msgstr "錯誤：--pause 百分比必須介於 1 到 99 之間"

msgid "Error: --resume flag can only be used with --upload"
msgstr "錯誤：--resume 標記只能與 --upload 一起使用"

msgid "Error: --pause and --resume cannot be used together"
msgstr "錯誤：--pause 和 --resume 不能同時使用"

msgid "Use --pause to pause a new upload, or --resume to continue a paused upload"
msgstr "使用 --pause 暫停新上傳，或使用 --resume 繼續已暫停的上傳"

msgid "Error: --auth-user requires --auth-password"
msgstr "錯誤：--auth-user 需要 --auth-password"

#, python-brace-format
msgid ""
"Use --auth-password to enable authentication (username defaults to "
"'{defaultUser}' if not specified)"
msgstr "使用 --auth-password 啟用身份驗證（如果未指定，使用者名稱預設為 '{defaultUser}'）"

#, python-brace-format
msgid "Error: --pickup-code must be exactly {n} digits"
